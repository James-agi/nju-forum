generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  name                     String
  password                 String
  avatar                   String?
  role                     Role                      @default(USER)
  banned                   Boolean                   @default(false)
  createdAt                DateTime                  @default(now())
  favorites                Favorite[]
  knowledgeAnswerFeedbacks KnowledgeAnswerFeedback[] @relation("KnowledgeAnswerFeedbackUser")
  knowledgeCardsCreated    KnowledgeCard[]           @relation("KnowledgeCardCreatedBy")
  knowledgeCardsUpdated    KnowledgeCard[]           @relation("KnowledgeCardUpdatedBy")
  KnowledgeConversation    KnowledgeConversation[]
  knowledgeGapsHandled     KnowledgeGap[]            @relation("KnowledgeGapHandledBy")
  knowledgeQuestions       KnowledgeQuestion[]       @relation("KnowledgeQuestionAsker")
  posts                    Post[]
  replies                  Reply[]
}

model Post {
  id         String     @id @default(cuid())
  title      String
  content    String
  images     String[]
  authorId   String
  sectionId  String
  viewCount  Int        @default(0)
  replyCount Int        @default(0)
  pinned     Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  favorites  Favorite[]
  author     User       @relation(fields: [authorId], references: [id])
  section    Section    @relation(fields: [sectionId], references: [id])
  replies    Reply[]
  tags       Tag[]      @relation("PostToTag")

  @@index([sectionId])
  @@index([authorId])
  @@index([createdAt])
}

model Reply {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  postId    String
  parentId  String?
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
  parent    Reply?   @relation("ReplyToReply", fields: [parentId], references: [id])
  children  Reply[]  @relation("ReplyToReply")
  post      Post     @relation(fields: [postId], references: [id])

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

model Section {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  icon        String?
  order       Int     @default(0)
  posts       Post[]
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  posts Post[] @relation("PostToTag")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
  @@index([postId])
}

model KnowledgeCard {
  id                 String              @id @default(cuid())
  summary            String
  body               String
  sourceUrl          String?
  sourceDescription  String
  sourceType         SourceType
  verificationStatus VerificationStatus
  domainTag          String
  createdById        String
  updatedById        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  archivedAt         DateTime?
  sourceExcerpt      String?
  sourceUrls         String?
  createdBy          User                @relation("KnowledgeCardCreatedBy", fields: [createdById], references: [id])
  updatedBy          User?               @relation("KnowledgeCardUpdatedBy", fields: [updatedById], references: [id])
  citations          KnowledgeCitation[]
  resolvedGaps       KnowledgeGap[]      @relation("KnowledgeGapLinkedCard")

  @@index([domainTag])
  @@index([verificationStatus])
  @@index([sourceType])
  @@index([archivedAt])
  @@index([createdById])
}

model KnowledgeQuestion {
  id                    String                    @id @default(cuid())
  askerId               String?
  originalText          String
  normalizedText        String
  status                QuestionStatus
  createdAt             DateTime                  @default(now())
  conversationId        String?
  turnIndex             Int                       @default(0)
  answer                KnowledgeAnswer?
  feedbacks             KnowledgeAnswerFeedback[] @relation("KnowledgeAnswerFeedbackQuestion")
  gap                   KnowledgeGap?
  asker                 User?                     @relation("KnowledgeQuestionAsker", fields: [askerId], references: [id])
  KnowledgeConversation KnowledgeConversation?    @relation(fields: [conversationId], references: [id])

  @@index([askerId])
  @@index([normalizedText])
  @@index([status])
  @@index([createdAt])
  @@index([conversationId, turnIndex])
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model KnowledgeAnswer {
  id         String              @id @default(cuid())
  questionId String              @unique
  answerText String
  createdAt  DateTime            @default(now())
  question   KnowledgeQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  citations  KnowledgeCitation[]
}

model KnowledgeCitation {
  id        String          @id @default(cuid())
  answerId  String
  cardId    String
  claimText String
  createdAt DateTime        @default(now())
  answer    KnowledgeAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  card      KnowledgeCard   @relation(fields: [cardId], references: [id])

  @@index([answerId])
  @@index([cardId])
}

model KnowledgeAnswerFeedback {
  id         String            @id @default(cuid())
  questionId String
  userId     String
  createdAt  DateTime          @default(now())
  note       String?
  archivedAt DateTime?
  question   KnowledgeQuestion @relation("KnowledgeAnswerFeedbackQuestion", fields: [questionId], references: [id], onDelete: Cascade)
  user       User              @relation("KnowledgeAnswerFeedbackUser", fields: [userId], references: [id])

  @@unique([questionId, userId])
  @@index([questionId])
  @@index([userId])
  @@index([createdAt])
  @@index([archivedAt])
}

model KnowledgeGap {
  id                 String             @id @default(cuid())
  questionId         String?            @unique
  originalQuestion   String
  normalizedQuestion String             @unique
  status             GapStatus          @default(OPEN)
  handledById        String?
  handledAt          DateTime?
  linkedCardId       String?
  duplicateOfId      String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  gapType            GapType            @default(CONTENT)
  duplicateOf        KnowledgeGap?      @relation("KnowledgeGapDuplicate", fields: [duplicateOfId], references: [id])
  duplicates         KnowledgeGap[]     @relation("KnowledgeGapDuplicate")
  handledBy          User?              @relation("KnowledgeGapHandledBy", fields: [handledById], references: [id])
  linkedCard         KnowledgeCard?     @relation("KnowledgeGapLinkedCard", fields: [linkedCardId], references: [id])
  question           KnowledgeQuestion? @relation(fields: [questionId], references: [id])

  @@index([normalizedQuestion])
  @@index([status])
  @@index([gapType])
  @@index([linkedCardId])
  @@index([duplicateOfId])
  @@index([handledById])
  @@index([createdAt])
}

model KnowledgeConversation {
  id                String              @id
  userId            String
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  expiresAt         DateTime?
  User              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  KnowledgeQuestion KnowledgeQuestion[]

  @@index([createdAt])
  @@index([isActive])
  @@index([userId])
}

enum Role {
  USER
  ADMIN
}

enum SourceType {
  OFFICIAL
  DOCUMENT
  SENIOR
  AUTHOR_EXPERIENCE
  OTHER
}

enum VerificationStatus {
  VERIFIED
  UNVERIFIED
  NEEDS_REVIEW
}

enum QuestionStatus {
  ANSWERED
  GAP_RECORDED
  OUT_OF_SCOPE
}

enum GapStatus {
  OPEN
  HANDLED
  DUPLICATE
  OUT_OF_SCOPE
}

enum GapType {
  CONTENT
  DATA
  ACTION
  POLICY_UNCLEAR
}
