server {
    listen 80;
    listen [::]:80;
    server_name njuknow.xyz www.njuknow.xyz;
    return 308 https://njuknow.xyz$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name njuknow.xyz www.njuknow.xyz;

    ssl_certificate /etc/letsencrypt/live/njuknow.xyz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/njuknow.xyz/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 20m;
    client_body_timeout 15s;
    client_header_timeout 15s;
    keepalive_timeout 30s;
    send_timeout 30s;
    limit_conn njuknow_conn_limit 30;

    proxy_hide_header X-Powered-By;
    proxy_hide_header Content-Security-Policy;
    proxy_hide_header Strict-Transport-Security;
    proxy_hide_header X-Content-Type-Options;
    proxy_hide_header X-Frame-Options;
    proxy_hide_header Referrer-Policy;
    proxy_hide_header Permissions-Policy;
    proxy_hide_header Cross-Origin-Resource-Policy;
    proxy_hide_header Cross-Origin-Opener-Policy;
    proxy_hide_header X-DNS-Prefetch-Control;
    proxy_hide_header X-Permitted-Cross-Domain-Policies;
    include /etc/nginx/snippets/njuknow-security-headers.conf;

    location = /api/auth/callback/credentials {
        limit_req zone=njuknow_auth_limit burst=5 nodelay;
        proxy_pass http://127.0.0.1:3000;
        include /etc/nginx/snippets/njuknow-proxy-params.conf;
    }

    location = /api/register {
        limit_req zone=njuknow_auth_limit burst=5 nodelay;
        proxy_pass http://127.0.0.1:3000;
        include /etc/nginx/snippets/njuknow-proxy-params.conf;
    }

    location = /api/send-verification {
        limit_req zone=njuknow_auth_limit burst=5 nodelay;
        proxy_pass http://127.0.0.1:3000;
        include /etc/nginx/snippets/njuknow-proxy-params.conf;
    }

    location ~ /\.(?!well-known(?:/|$)) {
        return 404;
    }

    location ~* ^/(?:\.git|\.env|node_modules|src|prisma|storage|package(?:-lock)?\.json|tsconfig\.json|next\.config\.mjs)(?:/|$) {
        return 404;
    }

    location ~ ^/_next/data/[^/]+/admin(?:/|\.json|$) {
        return 403;
    }

    location ^~ /_next/static/ {
        include /etc/nginx/snippets/njuknow-security-headers.conf;
        proxy_hide_header Cache-Control;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        proxy_pass http://127.0.0.1:3000;
        include /etc/nginx/snippets/njuknow-proxy-params.conf;
    }

    location ^~ /api/ {
        limit_req zone=njuknow_write_api_limit burst=30 nodelay;
        proxy_pass http://127.0.0.1:3000;
        include /etc/nginx/snippets/njuknow-proxy-params.conf;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        include /etc/nginx/snippets/njuknow-proxy-params.conf;
        proxy_cache_bypass $http_upgrade;
    }
}
